# SECURITY: the real env file may hold a real GRAPHIFY_MESH_OLLAMA_API_KEY.
# It must be chmod 0600 and owned by the service user — never world-readable.
#
# Environment for graphify-mesh-sync.service (systemd unit).
# NOT sourced by a shell — systemd EnvironmentFile= parses KEY=VALUE lines
# directly. Copy to graphify-mesh-sync.env and edit every value for your host.

# --- graphify-mesh paths (all optional; default to the process CWD) ---------
# Root that contains the graphify/global/ tree this engine publishes into.
GRAPHIFY_MESH_ROOT=/path/to/your/workspace/graph-mesh
# Root scanned for per-repo `graphify-out` symlinks (your repo checkouts).
GRAPHIFY_MESH_SCAN_ROOT=/path/to/your/workspace/checkouts
# registry.json path (defaults to <GRAPHIFY_MESH_ROOT>/bin/registry.json).
GRAPHIFY_MESH_REGISTRY=/path/to/your/workspace/graph-mesh/bin/registry.json

# --- Ollama (only used by the naming + embedding stages) --------------------
# LLM (community labeling) via the OpenAI-compatible /v1 surface + a dummy key.
GRAPHIFY_MESH_OLLAMA_BASE_URL=http://localhost:11434/v1
GRAPHIFY_MESH_OLLAMA_API_KEY=dummy
GRAPHIFY_MESH_OLLAMA_MODEL=qwen2.5-coder:14b
# Embeddings via the NATIVE /api/embed endpoint (no /v1 suffix).
GRAPHIFY_MESH_OLLAMA_EMBED_BASE_URL=http://localhost:11434
GRAPHIFY_MESH_OLLAMA_EMBED_MODEL=qwen3-embedding:0.6b

# --- upstream graphify CLI --------------------------------------------------
# Suppress graphify's dated snapshot backup dirs on every write.
GRAPHIFY_NO_BACKUP=1
# Executable name/path for the graphify CLI (override if it is not on PATH
# for the service's environment, e.g. a pinned pipx/venv binary).
GRAPHIFY_BIN=graphify
