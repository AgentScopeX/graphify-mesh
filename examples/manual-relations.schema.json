{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentscopex.github.io/graphify-mesh/schemas/manual-relations.schema.json",
  "title": "graphify-mesh manual cross-project relations",
  "description": "Human-declared cross-project overlay edges the sync engine cannot infer. Every source/target must resolve against the current generation's per-repo graphs at load time; a dangling reference is a hard error.",
  "type": "object",
  "additionalProperties": false,
  "required": ["relations"],
  "properties": {
    "relations": {
      "type": "array",
      "items": { "$ref": "#/$defs/relation" }
    }
  },
  "$defs": {
    "logical_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo", "source_file", "qualified_label"],
      "properties": {
        "repo": { "type": "string", "minLength": 1 },
        "source_file": { "type": "string", "minLength": 1 },
        "qualified_label": { "type": "string", "minLength": 1 },
        "signature": { "type": "string" }
      }
    },
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "source", "target"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["depends_on", "similar_approach", "provides_api", "consumes_api"]
        },
        "source": { "$ref": "#/$defs/logical_ref" },
        "target": { "$ref": "#/$defs/logical_ref" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidence": { "type": "string", "minLength": 1 }
      }
    }
  }
}
